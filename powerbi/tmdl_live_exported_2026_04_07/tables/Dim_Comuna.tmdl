table Dim_Comuna
	lineageTag: a86716e4-ae7b-4d03-817c-e65ba87f7a70

	column comuna_cod
		lineageTag: e4fc9898-dfee-49f9-bee5-59331dd6de26
		summarizeBy: none
		isNameInferred
		sourceColumn: [comuna_cod]

	column comuna_nombre
		lineageTag: a4666fa8-6278-428c-9e98-5bd779d98874
		isNameInferred
		sourceColumn: [comuna_nombre]

	partition Dim_Comuna = calculated
		mode: import
		source = ADDCOLUMNS(FILTER(DISTINCT(UNION(SELECTCOLUMNS(Hecho_Participacion_General, "comuna_cod", Hecho_Participacion_General[comuna_cod]), SELECTCOLUMNS(Hecho_Demografia, "comuna_cod", Hecho_Demografia[comuna_cod]), SELECTCOLUMNS(Hecho_Simulacros, "comuna_cod", Hecho_Simulacros[comuna_cod]))), NOT ISBLANK([comuna_cod])), "comuna_nombre", SWITCH([comuna_cod], 1, "Popular", 2, "Santa Cruz", 3, "Manrique", 4, "Aranjuez", 5, "Castilla", 6, "Doce de Octubre", 7, "Robledo", 8, "Villa Hermosa", 9, "Buenos Aires", 10, "La Candelaria", 11, "Laureles-Estadio", 12, "La America", 13, "San Javier", 14, "El Poblado", 15, "Guayabal", 16, "Belen", 50, "Palmitas", 60, "San Cristobal", 70, "Altavista", 80, "San Antonio de Prado", 90, "Santa Elena", BLANK()))

