	measure Actividades_Empresa =
			VAR _ComunasSeleccionadas = VALUES(Dim_Comuna[comuna_cod])
			VAR _MapaZonaComuna =
			    DATATABLE(
			        "zona_cam", STRING,
			        "comuna_cod", INTEGER,
			        {
			            {"Carabobo Norte", 4},
			            {"Carabobo Norte", 10},
			            {"Centro Oriental", 10},
			            {"Alpujarra", 10},
			            {"Belen Olaya", 15},
			            {"Belen Olaya", 16},
			            {"Guayabal Sur", 15},
			            {"Guayabal Norte", 15},
			            {"Robledo IES", 7},
			            {"Robledo IPS", 5},
			            {"Robledo IPS", 7},
			            {"Robledo IPS", 60},
			            {"La Presidenta", 14},
			            {"Perpetuo Socorro", 10},
			            {"FRATERNIDAD", 8},
			            {"CIUDAD DEL RIO", 14},
			            {"BARRIO COLOMBIA", 14},
			            {"CARIBE", 5},
			            {"La 30", 10},
			            {"Milla de Oro", 14},
			            {"Guayaquil", 10},
			            {"TESORO", 14}
			        }
			    )
			VAR _ZonasPermitidas =
			    SELECTCOLUMNS(
			        FILTER(_MapaZonaComuna, [comuna_cod] IN _ComunasSeleccionadas),
			        "zona_cam", [zona_cam]
			    )
			VAR _v =
			    CALCULATE(
			        DISTINCTCOUNT(CAM_Detalle[empresa_normalizada]),
			        KEEPFILTERS(TREATAS(_ZonasPermitidas, CAM_Detalle[zona_cam]))
			    )
			RETURN
			    IF(ISBLANK(_v), "0", FORMAT(_v, "#,##0"))
		displayFolder: Empresarial
		lineageTag: 2cf53097-1300-4f94-bd72-f2b411e62b8a

