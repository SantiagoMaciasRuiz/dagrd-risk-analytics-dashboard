	/// Numero de comites y comisiones distintos (excluye valor generico TODOS LOS COMITES Y COMISIONES).
	measure Num_Comites_Comisiones =
			VAR _n =
			    CALCULATE(
			        DISTINCTCOUNT(Dim_Comites_Comisiones_2026[comite_comision_nombre]),
			        KEEPFILTERS(TREATAS(VALUES(Dim_Comuna[comuna_cod]), Dim_Comites_Comisiones_2026[comuna_cod])),
			        KEEPFILTERS(Dim_Comites_Comisiones_2026[comite_comision_nombre] <> "TODOS LOS COMITES Y COMISIONES"),
			        KEEPFILTERS(NOT ISBLANK(Dim_Comites_Comisiones_2026[comite_comision_nombre]))
			    )
			RETURN
			    IF(ISBLANK(_n), "N/A", FORMAT(_n, "#,##0"))
		formatString: 0
		lineageTag: 78a5d1f2-0699-4be0-aeb9-d8984308c586

	/// Etiqueta año-mes para eje de tendencia (ej: 2024-07)
	measure Eje_AnioMes = FORMAT(MIN(Dim_Fecha[anio]), "0000") & "-" & FORMAT(MIN(Dim_Fecha[mes_num]), "00")
		lineageTag: dfb22f1c-7009-4afd-8c24-271ccc1e2e34

	/// Participaciones directas + personas simulacros + impacto indirecto
	measure Cobertura_Global =
			SUMX(
			    VALUES(Hecho_Participacion_General[seccion_tablero]),
			    [GenF_Total_Participaciones]
			) + [Base_Simulacros_Personas]
		formatString: #,##0
		lineageTag: 3100b730-cfb0-48d9-ab4d-6cfc5b80a8a4

