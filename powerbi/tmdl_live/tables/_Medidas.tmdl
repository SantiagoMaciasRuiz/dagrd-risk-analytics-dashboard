	/// Número de instituciones educativas únicas con las que se ha trabajado
	measure GenF_Edu_Instituciones_Unicas =
			VAR _ComunasSeleccionadas = VALUES(Dim_Comuna[comuna_cod])
			VAR _v =
			    CALCULATE(
			        DISTINCTCOUNT(Hecho_Participacion_General[institucion_educativa_norm]),
			        Hecho_Participacion_General[seccion_tablero] = "Educativa",
			        NOT(ISBLANK(Hecho_Participacion_General[institucion_educativa_norm])),
			        REMOVEFILTERS(Hecho_Participacion_General[comuna_cod]),
			        KEEPFILTERS(TREATAS(_ComunasSeleccionadas, Hecho_Participacion_General[comuna_institucion_educativa_cod]))
			    )
			RETURN
			    IF(ISBLANK(_v) || _v = 0, "N/A", FORMAT(_v, "#,##0"))
		displayFolder: Educativa/Instituciones
		lineageTag: a22a77ec-46e0-44d9-b540-8d2da138910b

	/// Cantidad de actividades de acompanamiento a planes escolares de gestion del riesgo en educativa; ignora filtros estructurales de seccion/instancia institucional para evitar blancos
	measure Edu_Acomp_PlanesEscolares_GRD =
			VAR _valor =
			    CALCULATE(
			        COUNTROWS(Hecho_Participacion_General),
			        REMOVEFILTERS(Dim_Seccion[seccion_tablero]),
			        REMOVEFILTERS(Dim_Instancia[instancia]),
			        REMOVEFILTERS(Hecho_Participacion_General[seccion_tablero]),
			        REMOVEFILTERS(Hecho_Participacion_General[instancia]),
			        REMOVEFILTERS(Hecho_Participacion_General[ambito_institucional]),
			        REMOVEFILTERS(Hecho_Participacion_General[grupo_ambito_comparacion]),
			        REMOVEFILTERS(Hecho_Participacion_General[bloque_institucional]),
			        REMOVEFILTERS(Hecho_Participacion_General[subbloque_institucional]),
			        Hecho_Participacion_General[seccion_tablero] = "Educativa",
			        CONTAINSSTRING(LOWER(COALESCE(Hecho_Participacion_General[actividad_educacion], "")), "plan escolar"),
			        CONTAINSSTRING(LOWER(COALESCE(Hecho_Participacion_General[actividad_educacion], "")), "acompa")
			    )
			RETURN
			    COALESCE(_valor, 0)
		displayFolder: Educativa
		lineageTag: 113de143-b958-4f09-bce4-6bd6131c4315

