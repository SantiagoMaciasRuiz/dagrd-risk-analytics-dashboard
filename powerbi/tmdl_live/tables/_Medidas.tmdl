	measure PAO_Total_Personas_VAL =
		VAR FechasSeleccionadas = VALUES(Dim_Fecha[fecha])
		RETURN
			CALCULATE(
				DISTINCTCOUNT(Hecho_Personas_Atendidas_Ordinario[idintegrante]),
				TREATAS(FechasSeleccionadas, Hecho_Personas_Atendidas_Ordinario[fecha_date])
			)
		isHidden
		lineageTag: 516707ac-66f1-4890-99fa-83761e1f6482

