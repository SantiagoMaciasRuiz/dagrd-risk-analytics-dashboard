	measure PAO_Grafica_Afectacion_Analitica_Rank_VAL =
			VAR grupoSeleccionado = SELECTEDVALUE(Dim_Grafica_PAO[Grupo])
			RETURN
			    IF(
			        ISBLANK([PAO_Grafica_Afectacion_Analitica_VAL]),
			        BLANK(),
			        RANKX(
			            FILTER(ALL(Dim_Grafica_PAO), Dim_Grafica_PAO[Grupo] = grupoSeleccionado),
			            [PAO_Grafica_Afectacion_Analitica_VAL],
			            ,
			            DESC,
			            DENSE
			        )
			    )
		formatString: 0
		displayFolder: PAO/Grafica
		lineageTag: 7663da26-cc26-42b5-b021-7cfd793dfd23

	measure PAO_Grafica_Afectacion_Analitica_Visible_VAL = IF(NOT(ISBLANK([PAO_Grafica_Afectacion_Analitica_VAL])) && [PAO_Grafica_Afectacion_Analitica_VAL] > 0, 1, BLANK())
		formatString: 0
		displayFolder: PAO/Grafica
		lineageTag: 172eb068-c7d2-40c3-8bbb-75cce6b21a5b

	measure PAO_Grafica_Afectacion_Analitica_Tooltip =
			VAR valor = [PAO_Grafica_Afectacion_Analitica_VAL]
			VAR pctGrupo = [PAO_Grafica_Afectacion_Analitica_Pct_Grupo_VAL]
			VAR pctTotal = [PAO_Grafica_Afectacion_Analitica_Pct_Total_VAL]
			RETURN
			    IF(
			        ISBLANK(valor),
			        BLANK(),
			        FORMAT(valor, "#,##0")
			            & " | Grupo: " & FORMAT(pctGrupo, "0.0%")
			            & " | Total: " & FORMAT(pctTotal, "0.0%")
			    )
		displayFolder: PAO/Grafica
		lineageTag: e60fdc6f-5337-4aaa-8b38-500f772fd8cc

	measure PAO_Grafica_Demografica_VAL =
			VAR g = SELECTEDVALUE(Dim_Grafica_PAO[Grupo])
			VAR s = SELECTEDVALUE(Dim_Grafica_PAO[Segmentacion])
			RETURN
			SWITCH(
			    TRUE(),
			    -- Genero (solo Hombre y Mujer)
			    g = "Género" && s = "Hombre", [PAO_Hombre_VAL],
			    g = "Género" && s = "Mujer", [PAO_Mujer_VAL],
			
			    -- Grupo etario
			    g = "Grupo etario" && s = "Menor de edad", [PAO_Menor_Edad_VAL],
			    g = "Grupo etario" && s = "Adulto", [PAO_Adulto_VAL],
			    g = "Grupo etario" && s = "Adulto mayor", [PAO_Adulto_Mayor_VAL],
			
			    -- Etnico (solo pertenencia etnica)
			    g = "Étnico" && s = "Afrodescendiente", [PAO_Etnia_Afrodescendiente_VAL],
			    g = "Étnico" && s = "Indígena", [PAO_Etnia_Indigena_VAL],
			    g = "Étnico" && s = "Negro", [PAO_Etnia_Negro_VAL],
			
			    -- Discapacidad (solo tipos de discapacidad)
			    g = "Discapacidad" && s = "Física", [PAO_Discapacidad_Fisica_VAL],
			    g = "Discapacidad" && s = "Psicosocial", [PAO_Discapacidad_Psicosocial_VAL],
			    g = "Discapacidad" && s = "Intelectual", [PAO_Discapacidad_Intelectual_VAL],
			    g = "Discapacidad" && s = "Múltiple", [PAO_Discapacidad_Multiple_VAL],
			    g = "Discapacidad" && s = "Visual", [PAO_Discapacidad_Visual_VAL],
			    g = "Discapacidad" && s = "Auditiva", [PAO_Discapacidad_Auditiva_VAL],
			
			    BLANK()
			)
		formatString: #,##0
		displayFolder: PAO/Grafica
		lineageTag: 02bbfc58-8eb6-42fe-9482-4310274ee241

	measure PAO_Grafica_Demografica_TotalGrupo_VAL = CALCULATE([PAO_Grafica_Demografica_VAL], ALLEXCEPT(Dim_Grafica_PAO, Dim_Grafica_PAO[Grupo]))
