	measure PAO_Grafica_Afectacion_VAL =
			VAR grupoSeleccionado = SELECTEDVALUE(Dim_Grafica_PAO[Grupo])
			VAR segmentacionSeleccionada = SELECTEDVALUE(Dim_Grafica_PAO[Segmentacion])
			RETURN
			    SWITCH(
			        TRUE(),
			        grupoSeleccionado = "Género" && segmentacionSeleccionada = "Hombre", [PAO_Hombre_VAL],
			        grupoSeleccionado = "Género" && segmentacionSeleccionada = "Mujer", [PAO_Mujer_VAL],
			        grupoSeleccionado = "Género" && segmentacionSeleccionada = "Intersexual", [PAO_Intersexual_VAL],
			        grupoSeleccionado = "Grupo etario" && segmentacionSeleccionada = "Menor de edad", [PAO_Menor_Edad_VAL],
			        grupoSeleccionado = "Grupo etario" && segmentacionSeleccionada = "Adulto", [PAO_Adulto_VAL],
			        grupoSeleccionado = "Grupo etario" && segmentacionSeleccionada = "Adulto mayor", [PAO_Adulto_Mayor_VAL],
			        grupoSeleccionado = "Étnico" && segmentacionSeleccionada = "Ninguna", [PAO_Etnia_Ninguna_VAL],
			        grupoSeleccionado = "Étnico" && segmentacionSeleccionada = "Afrodescendiente", [PAO_Etnia_Afrodescendiente_VAL],
			        grupoSeleccionado = "Étnico" && segmentacionSeleccionada = "Indígena", [PAO_Etnia_Indigena_VAL],
			        grupoSeleccionado = "Étnico" && segmentacionSeleccionada = "Negro", [PAO_Etnia_Negro_VAL],
			        grupoSeleccionado = "Étnico" && segmentacionSeleccionada = "Sin dato", [PAO_Etnia_Sin_Dato_VAL],
			        grupoSeleccionado = "Discapacidad" && segmentacionSeleccionada = "No tiene", [PAO_Discapacidad_No_Tiene_VAL],
			        grupoSeleccionado = "Discapacidad" && segmentacionSeleccionada = "Física", [PAO_Discapacidad_Fisica_VAL],
			        grupoSeleccionado = "Discapacidad" && segmentacionSeleccionada = "Psicosocial", [PAO_Discapacidad_Psicosocial_VAL],
			        grupoSeleccionado = "Discapacidad" && segmentacionSeleccionada = "Intelectual", [PAO_Discapacidad_Intelectual_VAL],
			        grupoSeleccionado = "Discapacidad" && segmentacionSeleccionada = "Múltiple", [PAO_Discapacidad_Multiple_VAL],
			        grupoSeleccionado = "Discapacidad" && segmentacionSeleccionada = "Visual", [PAO_Discapacidad_Visual_VAL],
			        grupoSeleccionado = "Discapacidad" && segmentacionSeleccionada = "Auditiva", [PAO_Discapacidad_Auditiva_VAL],
			        grupoSeleccionado = "Discapacidad" && segmentacionSeleccionada = "Desconocida", [PAO_Discapacidad_Desconocida_VAL],
			        grupoSeleccionado = "Discapacidad" && segmentacionSeleccionada = "Sin dato", [PAO_Discapacidad_Sin_Dato_VAL],
			        BLANK()
			    )
		formatString: #,##0
		displayFolder: PAO/Grafica
		lineageTag: 7b71cb58-50d5-418c-a5d5-98c0a61bde52

	measure PAO_Grafica_Afectacion_Analitica_VAL =
			VAR grupoSeleccionado = SELECTEDVALUE(Dim_Grafica_PAO[Grupo])
			VAR segmentacionSeleccionada = SELECTEDVALUE(Dim_Grafica_PAO[Segmentacion])
			RETURN
			    SWITCH(
			        TRUE(),
			        -- Genero (se muestran todas)
			        grupoSeleccionado = "Género" && segmentacionSeleccionada = "Hombre", [PAO_Hombre_VAL],
			        grupoSeleccionado = "Género" && segmentacionSeleccionada = "Mujer", [PAO_Mujer_VAL],
			        grupoSeleccionado = "Género" && segmentacionSeleccionada = "Intersexual", [PAO_Intersexual_VAL],
			
			        -- Grupo etario (se muestran todas)
			        grupoSeleccionado = "Grupo etario" && segmentacionSeleccionada = "Menor de edad", [PAO_Menor_Edad_VAL],
			        grupoSeleccionado = "Grupo etario" && segmentacionSeleccionada = "Adulto", [PAO_Adulto_VAL],
			        grupoSeleccionado = "Grupo etario" && segmentacionSeleccionada = "Adulto mayor", [PAO_Adulto_Mayor_VAL],
			
			        -- Etnico (solo poblacion etnica; se excluye Ninguna y Sin dato)
			        grupoSeleccionado = "Étnico" && segmentacionSeleccionada = "Afrodescendiente", [PAO_Etnia_Afrodescendiente_VAL],
			        grupoSeleccionado = "Étnico" && segmentacionSeleccionada = "Indígena", [PAO_Etnia_Indigena_VAL],
			        grupoSeleccionado = "Étnico" && segmentacionSeleccionada = "Negro", [PAO_Etnia_Negro_VAL],
			
			        -- Discapacidad (solo personas con discapacidad; se excluye No tiene, Desconocida, Sin dato)
			        grupoSeleccionado = "Discapacidad" && segmentacionSeleccionada = "Física", [PAO_Discapacidad_Fisica_VAL],
			        grupoSeleccionado = "Discapacidad" && segmentacionSeleccionada = "Psicosocial", [PAO_Discapacidad_Psicosocial_VAL],
			        grupoSeleccionado = "Discapacidad" && segmentacionSeleccionada = "Intelectual", [PAO_Discapacidad_Intelectual_VAL],
			        grupoSeleccionado = "Discapacidad" && segmentacionSeleccionada = "Múltiple", [PAO_Discapacidad_Multiple_VAL],
			        grupoSeleccionado = "Discapacidad" && segmentacionSeleccionada = "Visual", [PAO_Discapacidad_Visual_VAL],
			        grupoSeleccionado = "Discapacidad" && segmentacionSeleccionada = "Auditiva", [PAO_Discapacidad_Auditiva_VAL],
			
			        BLANK()
			    )
		formatString: #,##0
		displayFolder: PAO/Grafica
		lineageTag: fd4dfee0-dd0f-4250-8122-2cf9f39741a6

	measure PAO_Grafica_Afectacion_Analitica = IF(ISBLANK([PAO_Grafica_Afectacion_Analitica_VAL]), BLANK(), FORMAT([PAO_Grafica_Afectacion_Analitica_VAL], "#,##0"))
